---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import PhotoCard from "@/components/pages/gallery/PhotoCard.astro";
import { Icon } from "astro-icon/components";
import {
	profileConfig,
	momentPageConfig,
  getEnabledMoments,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

// 检查页面是否启用
if (!siteConfig.pages.moment) {
	return Astro.redirect("/404/");
}

const allMoments = await getEnabledMoments();
const allTags = [...new Set(allMoments.flatMap((item) => item.tags || []))].sort();

const columnCount = (length: number)=>{
  return length > 1 ? 2 : 1;
}

// 页面标题和描述
const title = momentPageConfig.title || i18n(I18nKey.moment);
const description = momentPageConfig.description || i18n(I18nKey.momentDescription);
const author = momentPageConfig.author || profileConfig.name;
const avatar = momentPageConfig.avatar || profileConfig.avatar;
---

<MainGridLayout title={title} description={description}>
  <div
    class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-4">
        <div class="flex items-center gap-3 mb-3">
          <div
            class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70"
          >
            <Icon name="material-symbols:camera" class="text-[1.5rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        {
          description && (
            <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
              {description}
            </p>
          )
        }
      </div>

      <!-- 搜索框 -->
      {allMoments.length > 0 && (
        <moment-filter class="mb-6">
          <div class="relative mb-3">
            <Icon
              name="material-symbols:search"
              class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 dark:text-neutral-500 text-lg pointer-events-none"
            />
            <input
              type="text"
              data-search
              placeholder={i18n(I18nKey.searchMoments) || "搜索动态..."}
              class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-(--line-divider) bg-transparent text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:border-(--primary) focus:ring-1 focus:ring-(--primary) outline-none transition-all duration-200 text-sm"
            />
          </div>
          <div class="flex flex-wrap gap-2">
            <button
              data-tag="all"
              class="btn-regular px-3 py-1.5 rounded-lg bg-(--primary) text-white hover:bg-(--primary) transition-colors duration-200 text-sm font-medium"
              >
              {i18n(I18nKey.all)}
            </button>
            {allTags.map((tag) => (
              <button
                data-tag={tag}
                class="btn-regular px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover) transition-colors duration-200 text-sm font-medium">
                {tag}
              </button>
            ))}
          </div>
        </moment-filter>
      )}

      {allMoments.length > 0 ? (
        <div class="moment-list">
          {allMoments.map((item, index) => (
            <article class="relative py-5 transition moment-card" data-tags={item.tags?.join(",")} 
              style={`border-bottom: ${index < allMoments.length - 1 ? '1px dashed var(--line-divider)' : 'none'};`}>
            <div class="flex items-start gap-4">
              <div class="max-w-12 relative shrink-0">
                <ImageWrapper
                  src={avatar || ""}
                  alt="Author"
                  class="mx-auto lg:w-full h-full lg:mt-0 rounded-full object-cover ring-2 ring-(--btn-card-bg-hover)"
                  loading="eager"
                  fetchpriority="high"
                  widths={[48]}
                  sizes="48px"
                />
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex min-w-0 items-start justify-between gap-3" > 
                  <div class="min-w-0">
                    <div class="truncate text-base font-bold text-(--primary)">{author}</div>
                    <time class="mt-0.5 block text-sm text-50">{item.datetime}</time> 
                  </div> 
                  <a href={`/moments/${item.id}/`} class="btn-plain h-11 w-11 shrink-0 rounded-lg text-50 active:scale-95" aria-label="View moment" > 
                    <Icon name="material-symbols:open-in-new-rounded" class="text-[1.5rem]" />
                  </a>
                </div>
                <div class="my-2 text-neutral-600 dark:text-neutral-400" >
                  {item.pinned && (
                    <span class="pinned-btn flex items-center gap-1 bg-(--btn-regular-bg) text-(--btn-content) rounded-md px-2 py-1.5 font-bold w-18 mb-2"><Icon name="material-symbols:pinboard" class="text-[1.2rem]" />置顶</span>
                  )}
                  <p class="content">
                    {item.content}
                    {item.tags.map((tag) => (
                      <span class="transition link text-(--primary) font-medium mx-1 cursor-pointer">#{tag}</span>
                    ))}
                  </p>
                </div>
                {item.imgurls.length > 0 && (
                  <div
                    class={`gallery-masonry max-w-[540px]`}
                    style={`column-count: ${columnCount(item.imgurls.length)}; column-gap: 0.75rem;`}
                  >
                    {item.imgurls.map((photo) => (
                      <PhotoCard src={photo} albumId={item.id} />
                    ))}
                  </div>
                )}
              </div>
            </div>
            </article>
          ))}
        </div>
      ):(
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
          <Icon name="material-symbols:photo-camera-rounded" class="text-6xl mb-4 opacity-50" />
          <p class="text-lg">{i18n(I18nKey.momentNoItem)}</p>
        </div>
      )}

      <!-- 筛选无结果提示 -->
      <div class="moment-empty hidden flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500">
        <Icon name="material-symbols:search-off-rounded" class="text-4xl mb-3" />
        <div class="text-sm">{i18n(I18nKey.searchNoResults)}</div>
      </div>
    </div>
  </div>

  <script slot="head" is:inline>
    if (!customElements.get("moment-filter")) {
      class MomentFilter extends HTMLElement {
        selectedTag = "all";

        constructor() {
          super();
        }

        connectedCallback() {
          this.addEventListener("click", this.handleClick);
          const input = this.querySelector("[data-search]");
          if (input) {
            input.addEventListener("input", () => this.applyFilters());
          }
        }

        disconnectedCallback() {
          this.removeEventListener("click", this.handleClick);
        }

        handleClick(e) {
          const target = e.target;
          const button = target.closest("button");
          if (!button) return;

          this.selectedTag = button.dataset.tag;
          const filters = this.querySelectorAll("button");

          filters.forEach((f) => {
            f.classList.remove("bg-(--primary)", "text-white");
            f.classList.remove("hover:bg-(--primary)");
            f.classList.add("bg-(--btn-regular-bg)", "text-(--btn-content)");
            f.classList.add("hover:bg-(--btn-regular-bg-hover)");

            if (f === button) {
              f.classList.remove("bg-(--btn-regular-bg)", "text-(--btn-content)");
              f.classList.remove("hover:bg-(--btn-regular-bg-hover)");
              f.classList.add("bg-(--primary)", "text-white");
              f.classList.add("hover:bg-(--primary)");
            }
          });

          this.applyFilters();
        }

        applyFilters() {
          const container = this.closest(".card-base");
          if (!container) return;

          const input = this.querySelector("[data-search]");
          const query = (input?.value || "").toLowerCase().trim();
          const cards = container.querySelectorAll(".moment-card");

          let hasVisible = false;

          cards.forEach((card) => {
            const cardEl = card;
            const content = (cardEl.querySelector(".content")?.textContent || "").toLowerCase();
            const tags = (cardEl.dataset.tags || "").split(",");

            const tagMatch =
              this.selectedTag === "all" ||
              (this.selectedTag && tags.includes(this.selectedTag));
            const searchMatch =
              !query ||
              content.includes(query) ||
              tags.some((t) => t.toLowerCase().includes(query));

            if (tagMatch && searchMatch) {
              cardEl.style.display = "";
              cardEl.classList.add("animate-fade-in-up");
              hasVisible = true;
            } else {
              cardEl.style.display = "none";
              cardEl.classList.remove("animate-fade-in-up");
            }
          });

          const emptyEl = container.querySelector(".moment-empty");
          if (emptyEl) {
            emptyEl.classList.toggle("hidden", hasVisible);
            emptyEl.classList.toggle("flex", !hasVisible);
          }
        }
      }
      customElements.define("moment-filter", MomentFilter);
    }
  </script>
</MainGridLayout>